---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="About | Space Explorer Blog">
  <main class="container about-page">
    <section class="card">
      <div class="eyebrow">About this site</div>
      <h1>A blog for sharing curiosity about space</h1>
      <p>This site is made for a young writer who wants to publish fun, educational articles about space. It is built to be simple to use, fast to load, and easy to manage with GitHub and Netlify.</p>
      <p>You can log in at <strong>/admin</strong> to create and edit posts.</p>
    </section>
  </main>
</BaseLayout>

<style>
  .about-page { padding: 3rem 0; }
  .card { background: white; border: 1px solid #dce9fb; border-radius: 30px; padding: 2rem; color: #102033; box-shadow: 0 18px 44px rgba(6, 30, 66, 0.1); }
  .eyebrow { color: #2c75b7; text-transform: uppercase; letter-spacing: .12em; font-weight: 800; font-size: .8rem; }
  h1 { font-size: clamp(2rem, 4vw, 3rem); margin: .5rem 0 1rem; }
  p { color: #546f8d; font-size: 1.05rem; line-height: 1.8; }
</style>
